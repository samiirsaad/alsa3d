<Window x:Class="AlSa3d.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="برنامج السعد للمحاسبة - Al-Sa3d" 
        Height="800" Width="1400"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        FontFamily="{StaticResource CairoFont}">
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- القائمة الجانبية -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" CornerRadius="0 10 10 0">
            <DockPanel>
                <!-- الشعار واسم البرنامج -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,20">
                    <TextBlock Text="🏢 برنامج السعد" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="للمحاسبة والفواتير" 
                               FontSize="14" 
                               Foreground="#BFDBFE"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
                
                <!-- أزرار التنقل -->
                <StackPanel Margin="10,20,10,0">
                    <Button Content="📊 لوحة التحكم" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Dashboard"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                    
                    <Button Content="👥 العملاء" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Customers"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                    
                    <Button Content="📄 الفواتير" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Invoices"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                    
                    <Button Content="📦 المنتجات" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Products"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                    
                    <Button Content="👨‍💼 الموظفين" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Employees"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                    
                    <Button Content="🏦 المالية" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Financial"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                    
                    <Button Content="📈 التقارير" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Reports"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                    
                    <Button Content="⚙️ الإعدادات" 
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,5"
                            Background="Transparent"
                            BorderBrush="#3B82F6"
                            BorderThickness="1"/>
                </StackPanel>
                
                <!-- معلومات المستخدم في الأسفل -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,20">
                    <Separator Background="#3B82F6" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding CurrentUserName}" 
                               Foreground="White" 
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentRole}" 
                               Foreground="#BFDBFE" 
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                    <Button Content="تسجيل الخروج" 
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,10,0,0"
                            Background="#DC2626"/>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- منطقة المحتوى الرئيسي -->
        <Grid Grid.Column="1" Margin="20">
            <!-- شريط علوي -->
            <DockPanel VerticalAlignment="Top" Margin="0,0,0,15">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding CurrentDate, StringFormat={}{0:dddd dd/MM/yyyy}}" 
                               FontSize="16" 
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="🔔" FontSize="20" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    <TextBlock Text="مرحباً بك في برنامج السعد" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
            
            <!-- منطقة عرض الشاشات -->
            <Border Background="{StaticResource SurfaceBrush}" 
                    CornerRadius="10"
                    Margin="0,50,0,0">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
