<UserControl x:Class="AlSa3d.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="إعدادات النظام" FontSize="28" FontWeight="Bold" Foreground="#2C3A47" FontFamily="Cairo"/>
                <TextBlock Text="تكوين النظام والعملات والصلاحيات" FontSize="14" Foreground="#747D8C" Margin="0,5,0,0" FontFamily="Cairo"/>
            </StackPanel>
        </Border>

        <!-- Settings Tabs -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
            <TabControl Background="Transparent" BorderBrush="#D1D8E0" FontFamily="Cairo">
                <TabItem Header="⚙️ الإعدادات العامة">
                    <StackPanel Margin="20">
                        <TextBlock Text="اسم الشركة" FontSize="14" Margin="0,0,0,5" FontFamily="Cairo"/>
                        <TextBox Padding="10" Margin="0,0,0,15" BorderBrush="#D1D8E0"/>
                        
                        <TextBlock Text="العملة الافتراضية" FontSize="14" Margin="0,0,0,5" FontFamily="Cairo"/>
                        <ComboBox Padding="10" Margin="0,0,0,15" Width="200" HorizontalAlignment="Left">
                            <ComboBoxItem Content="جنيه مصري (EGP)"/>
                            <ComboBoxItem Content="ريال سعودي (SAR)"/>
                            <ComboBoxItem Content="دولار أمريكي (USD)"/>
                        </ComboBox>
                        
                        <TextBlock Text="رقم الهاتف" FontSize="14" Margin="0,0,0,5" FontFamily="Cairo"/>
                        <TextBox Padding="10" Margin="0,0,0,15" BorderBrush="#D1D8E0"/>
                        
                        <Button Content="💾 حفظ الإعدادات" Background="#2E86DE" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Width="200"/>
                    </StackPanel>
                </TabItem>
                
                <TabItem Header="👥 إدارة المستخدمين">
                    <StackPanel Margin="20">
                        <TextBlock Text="صلاحيات المستخدمين والأدوار" FontSize="14" Margin="0,0,0,15" FontFamily="Cairo"/>
                        <Button Content="➕ إضافة مستخدم" Background="#2E86DE" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Width="200"/>
                    </StackPanel>
                </TabItem>
                
                <TabItem Header="🔒 النسخ الاحتياطي">
                    <StackPanel Margin="20">
                        <TextBlock Text="إعدادات النسخ الاحتياطي التلقائي" FontSize="14" Margin="0,0,0,15" FontFamily="Cairo"/>
                        <CheckBox Content="تفعيل النسخ الاحتياطي اليومي" Margin="0,0,0,15" FontFamily="Cairo"/>
                        <Button Content="📦 نسخ احتياطي الآن" Background="#26DE81" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left" Width="200"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
