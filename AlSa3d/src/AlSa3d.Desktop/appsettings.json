{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AlSa3d;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "AppSettings": {
    "CompanyName": "شركة السعد للمحاسبة",
    "DefaultCurrency": "EGP",
    "Language": "ar-EG",
    "Version": "1.0.0"
  },
  "Security": {
    "PasswordMinLength": 6,
    "TokenExpirationMinutes": 60,
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "Features": {
    "EnableBarcode": true,
    "EnableAutoBackup": true,
    "EnableNotifications": true,
    "EnableAuditLog": true,
    "MultiWarehouse": true,
    "MultiCurrency": true
  },
  "Backup": {
    "AutoBackupEnabled": true,
    "BackupIntervalHours": 24,
    "BackupPath": "./Backups",
    "MaxBackupFiles": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    },
    "FileLogging": {
      "Enabled": true,
      "Path": "./Logs/app-.log",
      "FileSizeLimitMB": 10,
      "RetainedFilesCount": 30
    },
    "DatabaseLogging": {
      "Enabled": true,
      "TableName": "AuditLogs"
    }
  },
  "Report": {
    "DefaultPaperSize": "A4",
    "DefaultOrientation": "Portrait",
    "LogoPath": "./Assets/logo.png",
    "FooterText": "شكراً لتعاملكم معنا - شركة السعد للمحاسبة"
  },
  "Print": {
    "DefaultPrinter": "",
    "Copies": 1,
    "ShowPrintDialog": false
  }
}
