<UserControl x:Class="AlSa3d.App.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="إدارة المنتجات" FontSize="28" FontWeight="Bold" Foreground="#2C3A47" FontFamily="Cairo"/>
                    <TextBlock Text="المنتجات والمخازن والتصنيفات" FontSize="14" Foreground="#747D8C" Margin="0,5,0,0" FontFamily="Cairo"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ منتج جديد" Background="#2E86DE" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="📦 جرد المخزون" Background="#D1D8E0" Foreground="#2C3A47" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Products Grid -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
            <DataGrid AutoGenerateColumns="False" Background="Transparent" 
                      BorderBrush="#D1D8E0" FontFamily="Cairo" RowHeight="50">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="م" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="اسم المنتج" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="التصنيف" Binding="{Binding CategoryName}" Width="120"/>
                    <DataGridTextColumn Header="سعر الشراء" Binding="{Binding PurchasePrice, StringFormat={}{0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="سعر البيع" Binding="{Binding SalePrice, StringFormat={}{0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinQuantity}" Width="80"/>
                    <DataGridTemplateColumn Header="الإجراءات" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Margin="0,0,5,0" Padding="8,4"/>
                                    <Button Content="🗑️" Padding="8,4"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
