<UserControl x:Class="AlSa3d.App.Views.EmployeeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="شؤون الموظفين" FontSize="28" FontWeight="Bold" Foreground="#2C3A47" FontFamily="Cairo"/>
                    <TextBlock Text="الموظفين والرواتب والحضور" FontSize="14" Foreground="#747D8C" Margin="0,5,0,0" FontFamily="Cairo"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ موظف جديد" Background="#2E86DE" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="💰 صرف الرواتب" Background="#26DE81" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Employees Grid -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
            <DataGrid AutoGenerateColumns="False" Background="Transparent" 
                      BorderBrush="#D1D8E0" FontFamily="Cairo" RowHeight="50">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="م" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="اسم الموظف" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="القسم" Binding="{Binding DepartmentName}" Width="120"/>
                    <DataGridTextColumn Header="الوظيفة" Binding="{Binding JobTitle}" Width="120"/>
                    <DataGridTextColumn Header="الراتب الأساسي" Binding="{Binding BasicSalary, StringFormat={}{0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="تاريخ التعيين" Binding="{Binding HireDate, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="الحالة" Binding="{Binding StatusName}" Width="80"/>
                    <DataGridTemplateColumn Header="الإجراءات" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✏️" Margin="0,0,5,0" Padding="8,4"/>
                                    <Button Content="📊" Margin="0,0,5,0" Padding="8,4"/>
                                    <Button Content="🗑️" Padding="8,4"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
