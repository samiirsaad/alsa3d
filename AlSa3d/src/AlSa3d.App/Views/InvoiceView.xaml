<UserControl x:Class="AlSa3d.App.Views.InvoiceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="#F5F6FA">
    <UserControl.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2E86DE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B5F9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#D1D8E0"/>
            <Setter Property="Foreground" Value="#2C3A47"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#26DE81"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="إدارة الفواتير" FontSize="28" FontWeight="Bold" Foreground="#2C3A47" FontFamily="Cairo"/>
                    <TextBlock Text="إنشاء وتعديل فواتير المبيعات والمشتريات" FontSize="14" Foreground="#747D8C" Margin="0,5,0,0" FontFamily="Cairo"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ فاتورة جديدة" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding CreateNewInvoiceCommand}" Margin="0,0,10,0"/>
                    <Button Content="📊 التقارير" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding ShowReportsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filters -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             FontFamily="Cairo" FontSize="14" Padding="10" 
                             BorderBrush="#D1D8E0" BorderThickness="1"/>
                    
                    <ComboBox Grid.Column="1" SelectedItem="{Binding SelectedStatus}" 
                              ItemsSource="{Binding InvoiceStatuses}" 
                              DisplayMemberPath="Name" Width="150" Margin="10,0"/>
                    
                    <Button Grid.Column="2" Content="🔍 بحث" Style="{StaticResource PrimaryButton}" 
                            Command="{Binding SearchInvoicesCommand}" Margin="10,0"/>
                    <Button Grid.Column="3" Content="🔄 تحديث" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding LoadInvoicesCommand}"/>
                </Grid>

                <!-- Invoices List -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Invoices}" 
                          SelectedItem="{Binding SelectedInvoice}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderBrush="#D1D8E0"
                          RowHeight="50"
                          ColumnHeaderHeight="45"
                          FontFamily="Cairo">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F1F2F6"/>
                            <Setter Property="Foreground" Value="#2C3A47"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E3F2FD"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الفاتورة" Binding="{Binding InvoiceNumber}" Width="100"/>
                        <DataGridTextColumn Header="العميل" Binding="{Binding CustomerName}" Width="150"/>
                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                        <DataGridTextColumn Header="الإجمالي" Binding="{Binding TotalAmount, StringFormat={}{0:N2}} ج.م" Width="100"/>
                        <DataGridTextColumn Header="المدفوع" Binding="{Binding PaidAmount, StringFormat={}{0:N2}} ج.م" Width="100"/>
                        <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingAmount, StringFormat={}{0:N2}} ج.م" Width="100"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding StatusName}" Width="100"/>
                        <DataGridTemplateColumn Header="الإجراءات" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="👁️" ToolTip="عرض" 
                                                Command="{Binding DataContext.ViewInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Margin="0,0,5,0" Style="{StaticResource SecondaryButton}" Padding="8,4"/>
                                        <Button Content="🖨️" ToolTip="طباعة" 
                                                Command="{Binding DataContext.PrintInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Margin="0,0,5,0" Style="{StaticResource SuccessButton}" Padding="8,4"/>
                                        <Button Content="🗑️" ToolTip="حذف" 
                                                Command="{Binding DataContext.DeleteInvoiceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" Padding="8,4"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
