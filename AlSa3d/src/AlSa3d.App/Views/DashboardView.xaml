<UserControl x:Class="AlSa3d.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="{StaticResource CairoFont}">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            <!-- العنوان -->
            <TextBlock Text="📊 لوحة التحكم" 
                       Style="{StaticResource Heading1}"
                       Margin="0,0,0,25"/>
            
            <!-- بطاقات الإحصائيات -->
            <UniformGrid Rows="1" Margin="0,0,0,30">
                <UniformGrid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </UniformGrid.ColumnDefinitions>
                
                <!-- بطاقة المبيعات -->
                <Border Background="#EFF6FF" CornerRadius="10" Padding="20" Margin="5">
                    <StackPanel>
                        <TextBlock Text="💰 إجمالي المبيعات" 
                                   FontSize="16" 
                                   Foreground="#1E40AF"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TotalSales, StringFormat={}{0:N0} ج.م}" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#1E3A8A"/>
                        <TextBlock Text="{Binding SalesCount, StringFormat={}{0} فاتورة}" 
                                   FontSize="14" 
                                   Foreground="#6B7280"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- بطاقة العملاء -->
                <Border Background="#ECFDF5" CornerRadius="10" Padding="20" Margin="5">
                    <StackPanel>
                        <TextBlock Text="👥 عدد العملاء" 
                                   FontSize="16" 
                                   Foreground="#065F46"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TotalCustomers}" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#064E3B"/>
                        <TextBlock Text="عميل نشط" 
                                   FontSize="14" 
                                   Foreground="#6B7280"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- بطاقة المنتجات -->
                <Border Background="#FEF3C7" CornerRadius="10" Padding="20" Margin="5">
                    <StackPanel>
                        <TextBlock Text="📦 المنتجات" 
                                   FontSize="16" 
                                   Foreground="#92400E"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding TotalProducts}" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#78350F"/>
                        <TextBlock Text="صنف متاح" 
                                   FontSize="14" 
                                   Foreground="#6B7280"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- بطاقة التنبيهات -->
                <Border Background="#FEE2E2" CornerRadius="10" Padding="20" Margin="5">
                    <StackPanel>
                        <TextBlock Text="⚠️ تنبيهات المخزون" 
                                   FontSize="16" 
                                   Foreground="#991B1B"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding LowStockCount}" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#7F1D1D"/>
                        <TextBlock Text="منتج منخفض المخزون" 
                                   FontSize="14" 
                                   Foreground="#6B7280"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            
            <!-- الفواتير الأخيرة -->
            <TextBlock Text="📄 آخر الفواتير" 
                       Style="{StaticResource Heading2}"
                       Margin="0,0,0,15"/>
            
            <DataGrid ItemsSource="{Binding RecentInvoices}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      Background="White"
                      BorderBrush="#E5E7EB"
                      RowHeight="45"
                      ColumnHeaderHeight="40">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="رقم الفاتورة" 
                                        Binding="{Binding InvoiceNumber}"
                                        Width="120"/>
                    <DataGridTextColumn Header="العميل" 
                                        Binding="{Binding CustomerName}"
                                        Width="200"/>
                    <DataGridTextColumn Header="التاريخ" 
                                        Binding="{Binding Date, StringFormat={}{0:dd/MM/yyyy}}"
                                        Width="120"/>
                    <DataGridTextColumn Header="الإجمالي" 
                                        Binding="{Binding TotalAmount, StringFormat={}{0:N2}}"
                                        Width="150"/>
                    <DataGridTextColumn Header="الحالة" 
                                        Binding="{Binding Status}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
            
            <Button Content="عرض جميع الفواتير" 
                    Command="{Binding ViewAllInvoicesCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Left"
                    Padding="20,10"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
