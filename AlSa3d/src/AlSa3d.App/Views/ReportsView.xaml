<UserControl x:Class="AlSa3d.App.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="التقارير والإحصائيات" FontSize="28" FontWeight="Bold" Foreground="#2C3A47" FontFamily="Cairo"/>
                    <TextBlock Text="تقارير المبيعات والمخزون والمالية" FontSize="14" Foreground="#747D8C" Margin="0,5,0,0" FontFamily="Cairo"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📤 تصدير PDF" Background="#2E86DE" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button Content="📊 تصدير Excel" Background="#26DE81" Foreground="White" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Reports List -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="20">
            <WrapPanel>
                <Border Background="#F1F2F6" CornerRadius="10" Padding="20" Margin="10" Width="250" Height="150">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="تقرير المبيعات" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Cairo"/>
                        <TextBlock Text="يومي - شهري - سنوي" FontSize="12" HorizontalAlignment="Center" Foreground="#747D8C" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#F1F2F6" CornerRadius="10" Padding="20" Margin="10" Width="250" Height="150">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="تقرير المخزون" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Cairo"/>
                        <TextBlock Text="حركة الأصناف" FontSize="12" HorizontalAlignment="Center" Foreground="#747D8C" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#F1F2F6" CornerRadius="10" Padding="20" Margin="10" Width="250" Height="150">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="💰" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="التقارير المالية" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Cairo"/>
                        <TextBlock Text="الأرباح والخسائر" FontSize="12" HorizontalAlignment="Center" Foreground="#747D8C" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Background="#F1F2F6" CornerRadius="10" Padding="20" Margin="10" Width="250" Height="150">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="👥" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="تقرير العملاء" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="Cairo"/>
                        <TextBlock Text="كشف الحسابات" FontSize="12" HorizontalAlignment="Center" Foreground="#747D8C" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
