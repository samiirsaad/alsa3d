<UserControl x:Class="AlSa3d.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FlowDirection="RightToLeft"
             FontFamily="{StaticResource CairoFont}">
    
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- شعار واسم البرنامج -->
        <StackPanel VerticalAlignment="Top" Margin="0,50,0,0">
            <TextBlock Text="🏢 برنامج السعد" 
                       FontSize="48" 
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="للمحاسبة والفواتير" 
                       FontSize="24"
                       Foreground="{StaticResource SecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </StackPanel>
        
        <!-- نموذج تسجيل الدخول -->
        <Border Grid.Row="0" VerticalAlignment="Center" 
                Background="{StaticResource SurfaceBrush}" 
                CornerRadius="15" 
                Padding="50"
                Width="400"
                Height="350">
            <StackPanel>
                <TextBlock Text="تسجيل الدخول" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>
                
                <TextBlock Text="اسم المستخدم" 
                           FontSize="14"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="16"
                         Margin="0,0,0,20"/>
                
                <TextBlock Text="كلمة المرور" 
                           FontSize="14"
                           Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword"
                             FontSize="16"
                             Margin="0,0,0,20"
                             PasswordChar="•"/>
                
                <Button Content="دخول" 
                        Command="{Binding LoginCommand}"
                        CommandParameter="{Binding ElementName=txtPassword}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,0"
                        FontSize="18"
                        Padding="0,12"/>
                
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        
        <!-- التذييل -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="0,0,0,20">
            <TextBlock Text="© 2026 برنامج السعد للمحاسبة - جميع الحقوق محفوظة" 
                       Foreground="#6B7280"
                       FontSize="12"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
